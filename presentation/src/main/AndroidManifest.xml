            android:name="com.google.android.geo.API_KEY"
            android:value="AIzaSyAXyouyT4cAxP6Rem17B1ocfKHTHKo0G8Q" />
            
        <!-- FileProvider para la captura de imágenes -->
        <provider
            android:name="androidx.core.content.FileProvider"
